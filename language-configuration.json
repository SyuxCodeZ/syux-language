{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["[", "]"],
        ["(", ")"],
        ["{", "}"]
    ],
    "autoClosingPairs": [
        ["[", "]"],
        ["(", ")"],
        ["{", "}"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["[", "]"],
        ["(", ")"],
        ["{", "}"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "markers": {
            "start": "\\[",
            "end": "\\]"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "\\[$",
        "decreaseIndentPattern": "^\\]"
    },
    "wordPattern": "[\\w_]+"
}